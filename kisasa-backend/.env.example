# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-firebase-project.firebasestorage.app
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Upload storage: use firebase on Render/production, local for development only
UPLOAD_STORAGE_BACKEND=firebase

# PostgreSQL Database (Use Neon or local PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
SQLALCHEMY_ECHO=True

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_TITLE=Kilimo Kisasa API
API_VERSION=1.0.0
API_DESCRIPTION=Agricultural Social Media Platform
DEBUG=True
ENVIRONMENT=development

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Server
HOST=0.0.0.0
PORT=8000
